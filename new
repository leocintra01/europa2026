<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Europa 2026 · Natalia</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #F8F6F1; --ink: #1C1C1C; --ink-light: #6B6B6B;
    --accent: #C4A882; --accent-dark: #8B6E4E;
    --ams: #1B5E8A; --bxl: #7B3F3F; --par: #2D6B3A;
    --white: #FFFFFF; --border: #E8E4DC; --tag-bg: #F0EDE6;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Mono', monospace; background: var(--bg); color: var(--ink); min-height: 100vh; font-size: 13px; }

.header { background: var(–ink); color: var(–bg); padding: 3rem 2rem 2rem; }
.header-line { width: 40px; height: 1px; background: var(–accent); margin-bottom: 1.5rem; }
.header h1 { font-family: ‘Cormorant Garamond’, serif; font-size: clamp(2.5rem, 8vw, 4.5rem); font-weight: 300; letter-spacing: -0.02em; line-height: 1; margin-bottom: 0.5rem; }
.header h1 em { font-style: italic; color: var(–accent); }
.header-meta { display: flex; gap: 2rem; margin-top: 1.5rem; font-size: 11px; letter-spacing: 0.08em; color: #999; text-transform: uppercase; flex-wrap: wrap; }
.header-meta span { color: var(–accent); }

.nav { display: flex; border-bottom: 1px solid var(–border); background: var(–white); overflow-x: auto; position: sticky; top: 0; z-index: 100; }
.nav-btn { padding: 1rem 1.5rem; border: none; background: transparent; font-family: ‘DM Mono’, monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(–ink-light); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; white-space: nowrap; }
.nav-btn.active { color: var(–ink); border-bottom-color: var(–ink); }
.nav-btn:hover { color: var(–ink); }

.section { display: none; padding: 2rem; max-width: 900px; margin: 0 auto; }
.section.active { display: block; }

.city-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0.8rem; border-radius: 2px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2rem; }
.city-badge.ams { background: #EAF2F8; color: var(–ams); }
.city-badge.bxl { background: #F5EBEB; color: var(–bxl); }
.city-badge.par { background: #EAF2EB; color: var(–par); }

.section-title { font-family: ‘Cormorant Garamond’, serif; font-size: 2rem; font-weight: 300; margin-bottom: 0.25rem; letter-spacing: -0.01em; }
.section-subtitle { font-size: 11px; color: var(–ink-light); letter-spacing: 0.05em; margin-bottom: 2rem; }

.hotel-card { background: var(–white); border: 1px solid var(–border); padding: 1.5rem; margin-bottom: 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.hotel-name { font-family: ‘Cormorant Garamond’, serif; font-size: 1.2rem; font-weight: 400; margin-bottom: 0.25rem; grid-column: 1 / -1; }
.hotel-detail { font-size: 11px; color: var(–ink-light); line-height: 1.8; }
.hotel-detail strong { color: var(–ink); font-weight: 400; display: block; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.2rem; }

.day-grid { display: flex; flex-direction: column; gap: 1px; background: var(–border); border: 1px solid var(–border); margin-bottom: 2rem; }
.day-row { display: grid; grid-template-columns: 100px 1fr; background: var(–white); min-height: 60px; }
.day-header { background: var(–ink); color: var(–bg); display: flex; flex-direction: column; justify-content: center; padding: 1rem; }
.day-header .day-name { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(–accent); margin-bottom: 0.2rem; }
.day-header .day-date { font-family: ‘Cormorant Garamond’, serif; font-size: 1.4rem; font-weight: 300; line-height: 1; }
.day-header .day-month { font-size: 10px; color: #888; margin-top: 0.1rem; }
.day-slots { display: flex; flex-direction: column; gap: 1px; background: var(–border); }
.slot { display: grid; grid-template-columns: 90px 1fr; background: var(–white); min-height: 50px; }
.slot-time { padding: 0.75rem 1rem; font-size: 10px; color: var(–ink-light); letter-spacing: 0.05em; border-right: 1px solid var(–border); display: flex; align-items: center; }
.slot-content { padding: 0.75rem 1rem; font-size: 12px; line-height: 1.6; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
.tag { display: inline-block; padding: 0.15rem 0.5rem; background: var(–tag-bg); font-size: 10px; letter-spacing: 0.05em; white-space: nowrap; }
.tag.confirmed { background: #EAF2EB; color: var(–par); }
.tag.warn { background: #FEF3E2; color: #9C6B00; }
.slot-night { background: #FAFAF8; }
.slot-night .slot-time { color: #BBB; }

.overview-table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; font-size: 11px; }
.overview-table th { background: var(–ink); color: var(–bg); padding: 0.75rem 1rem; text-align: left; font-weight: 400; letter-spacing: 0.08em; font-size: 10px; text-transform: uppercase; }
.overview-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(–border); vertical-align: top; line-height: 1.6; }
.overview-table tr:nth-child(even) td { background: #FAFAF8; }
.dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: 0.4rem; vertical-align: middle; }
.dot.ams { background: var(–ams); } .dot.bxl { background: var(–bxl); } .dot.par { background: var(–par); }

.train-card { background: var(–white); border: 1px solid var(–border); padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; display: grid; grid-template-columns: 1fr auto 1fr auto; align-items: center; gap: 1rem; }
.train-station .city { font-family: ‘Cormorant Garamond’, serif; font-size: 1.1rem; font-weight: 400; }
.train-station .time { font-size: 1.4rem; font-weight: 300; font-family: ‘Cormorant Garamond’, serif; }
.train-station .sub { font-size: 10px; color: #999; }
.train-arrow { color: var(–accent); font-size: 1.2rem; }
.train-meta { font-size: 10px; color: var(–ink-light); line-height: 1.8; text-align: right; }

.ticket-section-title { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(–ink-light); margin: 1.5rem 0 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(–border); }
.ticket-list { display: flex; flex-direction: column; gap: 1px; background: var(–border); border: 1px solid var(–border); margin-bottom: 1.5rem; }
.ticket-item { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 1rem; padding: 1rem 1.25rem; background: var(–white); }
.ticket-name { font-size: 13px; margin-bottom: 0.2rem; }
.ticket-meta { font-size: 10px; color: var(–ink-light); letter-spacing: 0.05em; line-height: 1.8; }
.ticket-status { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.3rem 0.7rem; white-space: nowrap; }
.ticket-status.comprar { background: #FEF3E2; color: #9C6B00; }
.ticket-status.comprado { background: #EAF2EB; color: var(–par); }
.ticket-link { font-size: 10px; color: var(–accent-dark); text-decoration: none; letter-spacing: 0.05em; margin-top: 0.2rem; display: block; }
.ticket-link:hover { text-decoration: underline; }

.budget-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1px; background: var(–border); border: 1px solid var(–border); margin-bottom: 1.5rem; }
.budget-card { background: var(–white); padding: 1.5rem; }
.budget-label { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(–ink-light); margin-bottom: 0.5rem; }
.budget-value { font-family: ‘Cormorant Garamond’, serif; font-size: 1.8rem; font-weight: 300; line-height: 1; margin-bottom: 0.25rem; }
.budget-sub { font-size: 10px; color: var(–ink-light); }
.budget-total .budget-value { color: var(–accent-dark); }

.coming-soon { padding: 3rem 2rem; text-align: center; border: 1px dashed var(–border); color: var(–ink-light); margin-top: 1rem; }
.coming-soon .cs-title { font-family: ‘Cormorant Garamond’, serif; font-size: 1.5rem; font-weight: 300; font-style: italic; margin-bottom: 0.5rem; color: var(–ink); }
.divider { height: 1px; background: var(–border); margin: 2rem 0; }

@media (max-width: 600px) {
.header { padding: 2rem 1.25rem 1.5rem; }
.section { padding: 1.5rem 1.25rem; }
.hotel-card { grid-template-columns: 1fr; }
.day-row { grid-template-columns: 75px 1fr; }
.slot { grid-template-columns: 70px 1fr; }
.train-card { grid-template-columns: 1fr 1fr; }
.train-arrow { display: none; }
}

.section.active > * { animation: fadeUp 0.4s ease both; }
.section.active > *:nth-child(2) { animation-delay: 0.05s; }
.section.active > *:nth-child(3) { animation-delay: 0.1s; }
.section.active > *:nth-child(4) { animation-delay: 0.15s; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
</style>

</head>
